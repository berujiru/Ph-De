# Copy to `.env` (or `.env.local`) and restart `vite` to apply.
# Only VITE_-prefixed vars are exposed to the client bundle.

# Show the Attack Sandbox entry on the Campaign map.
#   true  -> always show
#   false -> always hide
#   unset -> shown in dev builds, hidden in production
VITE_SHOW_SANDBOX=true

# AdMob rewarded ad unit IDs (native builds only; watch-for-permits in the store).
# Unset/blank -> Google's public test ad unit. Dev builds always use test mode.
VITE_ADMOB_ANDROID_REWARDED_ID=ca-app-pub-4958090008471573/3548496798
VITE_ADMOB_IOS_REWARDED_ID=ca-app-pub-4958090008471573/3548496798

# Show the real-money "Puhunan Counter" (Hope/Permit top-ups) on WEB builds,
# where purchases are simulated. Native builds always show it.
#   true  -> always show (simulated on web)
#   false -> always hide on web
#   unset -> shown in dev builds, hidden in production web
VITE_SHOW_IAP_WEB_SIM=true
